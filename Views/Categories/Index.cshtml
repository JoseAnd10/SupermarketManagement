@model List<Category>

@section title {
    <h3>Categories</h3>
}
<!-- Cada vez que se tenga que utilizar codigo de C# se tiene que utilizar el "arroba" -->

<!-- los tag helpers como asp-controller y asp-action se encargan de generar el enlace correcto a la acción del controlador, en este caso a la acción "edit" del controlador "categories" -->
@if (Model != null && Model.Count() > 0)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td>@category.Description</td>
                    <td><a class="btn btn-link" asp-controller="categories" asp-action="edit" asp-route-id="@category.CategoryId">Edit </a></td>
                   <td><a class="btn btn-link" asp-controller="categories" asp-action="delete" asp-route-categoryid="@category.CategoryId" onclick="return confirmDelete()">Delete</a></td>
                </tr>
            }
        </tbody>
    </table>
    <a class="btn btn-primary" asp-controller="categories" asp-action="add">Add</a>
}


<!-- Este Section debe de ser instanciado primeramente en _Layout para poder utilizarlo -->
@section Scripts {
    <script>
        function confirmDelete(){
            return confirm("Are you sure you want to delete this category?");
        }
    </script>
}